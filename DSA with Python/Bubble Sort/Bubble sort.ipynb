     ]
    }
   ],
   "source": [
    "def bubblesort(a):\n",
    "    n = len(a)\n",
    "    \n",
    "    for i in range (n):\n",
    "        for j in range(0, n-1-i):\n",
    "            if(a[j] > a[j+1]):\n",
    "                a[j], a[j+1] = a[j+1], a[j]\n",
    "        \n",
    "a = [64,32,25,45,40,51,2]\n",
    "bubblesort(a)\n",
    "print(a)"
   ]
  },
